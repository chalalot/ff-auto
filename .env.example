# ---------------------------------------------------------------------------
# Environment configuration for ff-auto
# Copy to .env and fill in real values. Do NOT commit .env.
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---------------------------------------------------
# The application resolves its connection via DATABASE_URL (single source of
# truth, see backend/database/db_utils.py). In docker-compose the URL points
# at the "postgres" service; locally point it wherever your Postgres lives.
POSTGRES_USER=ffauto
POSTGRES_PASSWORD=ffauto
POSTGRES_DB=ffauto
DATABASE_URL=postgresql://ffauto:ffauto@postgres:5432/ffauto

# --- Celery / Redis --------------------------------------------------------
CELERY_BROKER_URL=redis://global-redis:6379/1
CELERY_RESULT_BACKEND=redis://global-redis:6379/2

# --- Google Cloud ----------------------------------------------------------
GCS_CREDENTIALS_PATH=/app/soulie-gcp-bucket.json

# --- Third-party API keys (fill in as needed) ------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
HF_TOKEN=
